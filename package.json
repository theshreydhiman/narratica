{
  "name": "narratica",
  "version": "1.0.0",
  "description": "AI-Powered Creative Writing Platform",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=shared && npm run build --workspace=client",
    "lint": "concurrently \"npm run lint --workspace=client\" \"npm run lint --workspace=server\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
